   CSS
/* Reset */
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

/* Body */
body {
    font-family: Arial, sans-serif;
}

/* Navbar */
nav {
    position: fixed;
    top: 0;
    width: 100%;
    padding: 15px 30px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: transparent;
    transition: 0.3s;
}

/* Scroll Effect */
nav.scrolled {
    background: #333;
    box-shadow: 0 2px 5px rgba(0,0,0,0.3);
}

/* Logo */
.logo {
    color: white;
    font-size: 24px;
    font-weight: bold;
}

/* Nav Links */
.nav-links {
    list-style: none;
    display: flex;
}

.nav-links li {
    margin: 0 15px;
}

.nav-links a {
    text-decoration: none;
    color: white;
    font-size: 18px;
    transition: 0.3s;
}

/* Hover Effect */
.nav-links a:hover {
    color: yellow;
    transform: scale(1.1);
}

/* Content */
.content {
    height: 100vh;
    padding-top: 80px;
    text-align: center;
    background: linear-gradient(to right, #4facfe, #00f2fe);
    color: white;
}

/* Responsive */
@media (max-width: 768px) {
    .nav-links {
        flex-direction: column;
        background: #333;
        position: absolute;
        top: 60px;
        right: 0;
        width: 200px;
        display: none;
    }
}
